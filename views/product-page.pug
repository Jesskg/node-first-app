extends layouts/main-layout.pug


block styles 
    link(rel="stylesheet", href="/css/product.css")
    link(rel="stylesheet", href="/css/forms.css")

block content
    main
        form.product-form(action="/admin/product-page", method="post")
            .form-control
                label(for="title") Title
                    input(type="text", name="title", placeholder="Product Name")#title
            button(type="submit", aria-placeholder="What product do you want?") Add Product  

